# Claude / Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx
# 日常内容生成用 Haiku 省钱，重点文章用 Sonnet
ANTHROPIC_MODEL=claude-haiku-4-20250514
ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-20250514

# DeepSeek API (当前实际使用的 API 后端)
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Google (可选，用于 Search Console + Analytics)
GOOGLE_SEARCH_CONSOLE_KEY=
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Amazon Associates (可选，Phase 3)
AMAZON_ASSOCIATES_TAG=your-tag-20
AMAZON_ASSOCIATES_REGION=us

# 1688 / 电商爬取 (可选，Phase 4)
PROXY_URL=http://user:pass@proxy:8080
