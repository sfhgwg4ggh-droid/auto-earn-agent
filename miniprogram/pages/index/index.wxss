.hero{background:linear-gradient(135deg,#4A7C59,#3A6347);color:#fff;text-align:center;padding:48rpx 32rpx}
.hero-title{font-size:40rpx;font-weight:800;margin-bottom:8rpx}
.hero-desc{font-size:24rpx;opacity:.85}
.slogan{text-align:center;padding:24rpx;font-size:26rpx;color:#8b6914;background:linear-gradient(170deg,#fff7ed,#fef3c7)}
.product-list{padding:20rpx}
.product{background:#fff;border-radius:16rpx;overflow:hidden;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);margin-bottom:24rpx}
.product-img-wrap{position:relative;background:#fdfaf3;display:flex;align-items:center;justify-content:center;height:500rpx}
.product-img{width:100%;height:100%}
.product-img-wrap .tag{position:absolute;top:16rpx;left:16rpx}
.product-info{padding:24rpx}
.product-name{font-size:32rpx;font-weight:700;margin-bottom:8rpx}
.product-desc{font-size:24rpx;color:#9b8b7e;margin-bottom:20rpx}
.product-bottom{display:flex;justify-content:space-between;align-items:center}
.buy-btn{background:#4A7C59;color:#fff;font-size:26rpx;font-weight:700;padding:12rpx 32rpx;border-radius:32rpx}
.buy-btn:active{background:#3A6347}
.how-to{background:#f5f1eb;margin:20rpx;border-radius:16rpx;padding:28rpx}
.how-to .title{font-size:28rpx;font-weight:700;color:#8b6914;margin-bottom:20rpx}
.steps{display:flex;justify-content:space-around}
.step{display:flex;flex-direction:column;align-items:center;font-size:22rpx;color:#6b5c47;gap:8rpx}
.step .num{width:40rpx;height:40rpx;border-radius:50%;background:#4A7C59;color:#fff;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:700}
.footer{text-align:center;padding:32rpx;color:#9b8b7e;font-size:22rpx}
.footer-small{display:block;font-size:20rpx;margin-top:4rpx}
