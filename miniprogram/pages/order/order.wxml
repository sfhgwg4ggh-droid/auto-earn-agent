<view class="order">
  <!-- 商品信息 -->
  <view class="product-summary">
    <image class="summary-img" src="/images/{{product.name}}.png" mode="aspectFit" />
    <view class="summary-info">
      <view class="summary-name">{{product.emoji}} {{product.name}}</view>
      <view class="price price-big">¥{{product.price}}</view>
      <view class="summary-meta">📥 电子版 · 即时交付</view>
    </view>
  </view>

  <!-- 订单表单 -->
  <view class="form">
    <view class="form-title">📝 填写下单信息</view>

    <view class="form-item">
      <view class="label">微信昵称</view>
      <input placeholder="怎么称呼你？" value="{{nickName}}" bindinput="onNickInput" />
    </view>

    <view class="form-item">
      <view class="label">📱 手机号 <text class="required">*</text></view>
      <input type="number" placeholder="用来接收交付通知" value="{{phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="form-item">
      <view class="label">📧 邮箱（接收文件）<text class="required">*</text></view>
      <input type="text" placeholder="高清文件发到这里" value="{{email}}" bindinput="onEmailInput" />
    </view>

    <view class="form-item">
      <view class="label">🐾 宠物名字 <text class="required">*</text></view>
      <input placeholder="你家毛孩子叫什么？" value="{{petName}}" bindinput="onPetNameInput" />
    </view>

    <view class="form-item">
      <view class="label">📝 特殊要求</view>
      <textarea placeholder="如：背景颜色、风格偏好、特别说明…" value="{{note}}" bindinput="onNoteInput" maxlength="200" />
    </view>

    <!-- 上传照片 -->
    <view class="form-item">
      <view class="label">📸 上传宠物照片 <text class="required">*</text></view>
      <view class="photo-area" bindtap="choosePhoto">
        <image wx:if="{{photoPath}}" class="photo-preview" src="{{photoPath}}" mode="aspectFill" />
        <view wx:else class="photo-placeholder">
          <text class="photo-icon">📷</text>
          <text>点击选择照片</text>
          <text class="photo-hint">光线好的正面照最佳</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 支付 -->
  <view class="form">
    <view class="form-title">💰 支付方式</view>

    <view class="pay-tabs">
      <view class="pay-tab {{payMethod==='wechat'?'active':''}}" bindtap="switchPay" data-method="wechat">
        <text class="pay-icon">🟢</text>微信支付
      </view>
      <view class="pay-tab {{payMethod==='alipay'?'active':''}}" bindtap="switchPay" data-method="alipay">
        <text class="pay-icon">🔵</text>支付宝
      </view>
    </view>

    <view class="qr-section">
      <text class="qr-title">📱 请扫码支付 <text class="price price-big">¥{{product.price}}</text></text>
      <image wx:if="{{payMethod==='wechat'}}" class="qr-box" src="/images/wechat-qr.png" mode="aspectFit" />
      <image wx:else class="qr-box" src="/images/alipay-qr.png" mode="aspectFit" />
      <text class="qr-desc">请截图保存付款成功页面</text>
    </view>
  </view>

  <!-- 提交 -->
  <view class="submit-area">
    <button class="btn-gold btn-submit" bindtap="submitOrder" loading="{{submitting}}" disabled="{{submitting}}">
      📤 提交订单
    </button>
    <view class="submit-hint">提交后请付款 · 24小时内开始制作</view>
  </view>
</view>
